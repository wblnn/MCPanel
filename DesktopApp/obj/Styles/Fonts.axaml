<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style Selector="TextBlock, Button, TextBox, ListBox, Border">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Microsoft YaHei, SimSun, sans-serif"/>
    </Style>
    
</Styles>